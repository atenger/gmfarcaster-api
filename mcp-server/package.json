{
  "name": "gmfarcaster-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Warpee Knowledge API — query the GM Farcaster podcast archive from any MCP client. Pay-per-call via x402 (USDC on Base); no API keys.",
  "type": "module",
  "bin": {
    "gmfarcaster-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "prepare": "npm run build",
    "start": "node build/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "farcaster",
    "gm-farcaster",
    "warpee",
    "x402",
    "knowledge-api"
  ],
  "license": "MIT",
  "author": "GM Farcaster Network",
  "homepage": "https://github.com/atenger/gmfarcaster-api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atenger/gmfarcaster-api.git",
    "directory": "mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/evm": "^2.17.0",
    "@x402/fetch": "^2.17.0",
    "viem": "^2.21.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
